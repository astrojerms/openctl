# K3s E2E Test Configuration
# Copy this file to .env.e2e and fill in your values
# .env.e2e is gitignored and will not be committed

# Proxmox settings
PROXMOX_NODE="pve1"
PROXMOX_STORAGE="local"
PROXMOX_DISK_STORAGE="local-lvm"

# Network settings for static IPs (recommended)
USE_STATIC_IPS="true"
STATIC_IP_START="192.168.1.200"
STATIC_IP_GATEWAY="192.168.1.1"
STATIC_IP_NETMASK="24"
NETWORK_BRIDGE="vmbr0"

# SSH settings
SSH_USER="ubuntu"
SSH_KEY_PATH="$HOME/.ssh/id_ed25519"
# Optional: specify public key directly instead of reading from .pub file
# SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"

# Cloud image URL
CLOUD_IMAGE_URL="https://cloud-images.ubuntu.com/jammy/current/jammy-server-cloudimg-amd64.img"
