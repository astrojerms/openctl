# Binaries
bin/
*.exe
*.exe~
*.dll
*.so
*.dylib

# Stray root-level build outputs from `go build ./cmd/...` / `./plugins/...`
# without -o (they land in the repo root). Ignore the known binary names so
# an accidental bare build can't be committed.
/openctl
/openctl-controller
/openctl-proxmox
/openctl-k3s
/openctl-k3s-agent
/example

# Test binary
*.test

# Output of go coverage
*.out

# Go workspace
go.work
go.work.sum

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Secrets (never commit)
secrets/
*.token
*.key
*.pem

# E2E test config (contains personal settings)
.env.e2e
.env.e2e.local
**/test/e2e/.env.e2e
**/test/e2e/.env.e2e.local

# Generated test manifests
**/test/e2e/*-test-manifest.yaml

# Local cluster manifests (contain personal env: IPs, SSH keys, template names)
.cluster.yaml
.cluster*.yaml

# AI
.claude
