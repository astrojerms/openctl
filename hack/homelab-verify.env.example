# homelab-verify.env — config for hack/homelab-verify.sh
#
# Copy to homelab-verify.env (gitignored) and fill in for your homelab:
#   cp hack/homelab-verify.env.example homelab-verify.env
#
# This file holds NO secrets. The Proxmox API token lives in the controller's
# config (tokenSecretFile), set up during the QUICKSTART — the harness only
# drives the already-configured controller.

# openctl binary (default: whatever is on PATH)
# OPENCTL=./bin/openctl

# --- Proxmox placement (REQUIRED) -------------------------------------------
PROXMOX_NODE=pve1                       # target Proxmox node name
PROXMOX_TEMPLATE=ubuntu-22.04-cloudinit # cloud-init template that already exists
PROXMOX_STORAGE=local-lvm
PROXMOX_BRIDGE=vmbr0

# --- SSH (REQUIRED: pubkey; privkey needed for the cluster path) ------------
SSH_USER=ubuntu
SSH_PUBKEY="ssh-ed25519 AAAA... you@host"   # cloud-init injects this
SSH_PRIVKEY_PATH=~/.ssh/id_ed25519          # k3s installs over SSH with this

# --- Sandbox VM (fast path) -------------------------------------------------
# The harness only touches this exact name and refuses to start if it exists.
VERIFY_VM_NAME=openctl-verify-vm
VM_CPUS=2
VM_MEMORY_MB=2048
VM_MEMORY_MB_BUMP=4096          # re-applied to exercise #73 no-op-on-existing
VM_DISK=20G
# Static IP recommended (QGA-free templates won't report a DHCP lease).
# Leave VM_IP empty to use DHCP. Pick an address OUTSIDE your cluster range.
VM_IP=192.168.1.234/24
VM_GATEWAY=192.168.1.1

# --- Sandbox cluster (slow path, --cluster) ---------------------------------
# Defaults to the .235-.238 range (safe per your homelab notes: avoids the
# Synology at .241 and the .240-243/.230-233 collisions).
VERIFY_CLUSTER_NAME=openctl-verify
CLUSTER_CP_COUNT=1
CLUSTER_WORKER_COUNT=1
CLUSTER_CPUS=2
CLUSTER_MEM_MB=4096
CLUSTER_DISK_GB=30
CLUSTER_IP_START=192.168.1.235
CLUSTER_GATEWAY=192.168.1.1
CLUSTER_NETMASK=24
